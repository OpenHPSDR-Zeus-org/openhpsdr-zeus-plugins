{
  "schemaVersion": 1,
  "id": "com.openhpsdr.zeus.plugins.pgxl",
  "name": "Power Genius XL",
  "version": "1.0.0",
  "author": "Brian Keating (EI6LF)",
  "description": "4O3A Power Genius XL solid-state amplifier control. UDP discovery and TCP control on :9008; surfaces operate/standby, A/B band+bias, forward power, SWR, drive, PA current, temperature, and FlexRadio pairing override.",
  "homepage": "https://github.com/brianbruff/openhpsdr-zeus-plugins",
  "license": "GPL-2.0-or-later",
  "sdk": { "abi": 1, "minVersion": "1.0.0" },
  "entrypoint": {
    "assembly": "PowerGeniusXL.dll",
    "type": "Openhpsdr.Zeus.Plugins.PowerGeniusXL.PgxlPlugin"
  },
  "capabilities": ["PersistSettings"],
  "permissions": {
    "network": true
  },
  "ui": {
    "modules": ["ui/pgxl.es.js"],
    "panels": [
      {
        "id": "pgxl.main",
        "title": "Power Genius XL",
        "icon": "Zap",
        "slot": "workspace.amplifier"
      }
    ]
  }
}
