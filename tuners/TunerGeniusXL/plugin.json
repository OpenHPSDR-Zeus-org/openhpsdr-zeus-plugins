{
  "schemaVersion": 1,
  "id": "com.openhpsdr.zeus.plugins.tgxl",
  "name": "Tuner Genius XL",
  "version": "1.0.0",
  "author": "Brian Keating (EI6LF)",
  "description": "4O3A Tuner Genius XL antenna tuner control — UDP :9010 discovery, TCP :9010 control. One L/C network serving up to two radios (SO2R).",
  "homepage": "https://github.com/brianbruff/openhpsdr-zeus-plugins",
  "license": "GPL-2.0-or-later",
  "sdk": { "abi": 1, "minVersion": "1.0.0" },
  "entrypoint": {
    "assembly": "TunerGeniusXL.dll",
    "type": "Openhpsdr.Zeus.Plugins.TunerGeniusXL.TgxlPlugin"
  },
  "capabilities": ["NetworkAccess", "PersistSettings"],
  "permissions": {
    "network": true
  },
  "ui": {
    "modules": ["ui/tgxl.es.js"],
    "panels": [
      {
        "id": "tgxl.main",
        "title": "Tuner Genius XL",
        "icon": "Radio",
        "slot": "workspace.tuner",
        "category": "tuners"
      }
    ]
  }
}
